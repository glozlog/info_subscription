e_info":{"status":0,"star_altar_order_id":0,"star_altar_type":0,"item_id":0},"mark_largely_following":false,"friend_recommend_info":{"friend_recommend_source":10,"label_user_list":null,"disable_friend_recommend_guide_label":false},"enable_comment_sticker_rec":false,"video_share_edit_status":0,"is_24_story":0,"recommend_chapter_info":{"recommend_chapter_list":[{"desc":"引言","timestamp":0,"detail":"","points":[]},{"desc":"永久投资组合的原理","timestamp":34000,"detail":"","points":[{"desc":"・永久投资组合核心逻辑","detail":"1. 提出背景：由哈里·布朗于上世纪80年代提出，核心是四类低相关性资产均衡配置，不追求最大化收益，目标是全经济周期稳健增长\n2. 资产配置：初始将资金均分至股票、黄金、现金、国债四类资产，各占25%；当单类资产占比超35%或低于15%时，重新平衡至25%\n3. 周期适配：对应繁荣、通胀、衰退、通缩四大经济周期，总有一类资产在对应周期表现优异，实现风险对冲","type":1}]},{"desc":"策略构建与回测","timestamp":105000,"detail":"","points":[{"desc":"・量化回测策略构建","detail":"1. 标的选择：选取沪深300ETF、黄金ETF、10年期国债ETF、货币基金ETF作为实操标的，确保策略可落地\n2. 运行规则：初始按25%比例分别买入四类资产，持续持有；当单类资产占比超35%或低于15%时，重新平衡至25%","type":1},{"desc":"・沪深300版组合回测表现","detail":"1. 收益数据：2018年至今净值从1升至1.76，年化收益7.32%，最大回撤仅8.61%，风格稳健\n2. 结构分析：黄金贡献60%收益，沪深300贡献21%；回撤主要来自沪深300，占比约59%","type":1}]},{"desc":"沪深300指数","timestamp":183500,"detail":"","points":[{"desc":"・沪深300版组合特点","detail":"1. 收益结构：虽理论上股票应为主要收益来源，但实际60%收益来自黄金，沪深300仅贡献21%，且是主要回撤来源\n2. 策略优势：无论市场环境如何，总有一类资产表现优异，体现永久投资组合的对冲效果","type":1}]},{"desc":"纳指","timestamp":218000,"detail":"","points":[{"desc":"・纳指版组合回测与实操","detail":"1. 收益表现：2018年至今净值涨至2.39，年化收益11.53%，最大回撤9.39%，收益和风险均高于沪深300版\n2. 结构变化：纳指成为核心资产，贡献51%收益；回撤也主要来自纳指，占比约61%\n3. 实操限制：2018年纳指ETF规模仅几亿，国内关注度低，当时投资者更倾向选沪深300ETF","type":1}]},{"desc":"低价股小市值策略","timestamp":231000,"detail":"","points":[]},{"desc":"总结","timestamp":279500,"detail":"","points":[]}],"chapter_recommend_type":1,"chapter_abstract":"永久投资组合是一种通过资产配置实现风险对冲和稳定收益的策略。通过回测不同资产配置的策略，发现永久投资组合在降低风险的同时能获得较为稳定的收益。与其他策略相比，永久投资组合更适合个人投资者，因为其原理简单，历史波动较小。","chapter_recommend_source":2,"push_scene":[],"chapter_bar_color":null}},{"aweme_id":"7605865314823228691","desc":"趋势之王or虚有其表？ A股均线知多少？ #量化投资 #理财 #A股 #股票 #掘金计划2026","create_time":1771556400,"author":{"