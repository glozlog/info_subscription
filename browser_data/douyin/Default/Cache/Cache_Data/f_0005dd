":null,"disable_friend_recommend_guide_label":false},"enable_comment_sticker_rec":false,"video_share_edit_status":0,"is_24_story":0,"recommend_chapter_info":{"recommend_chapter_list":[{"desc":"引言","timestamp":1000,"detail":"","points":[]},{"desc":"女性择偶心态的转变","timestamp":45000,"detail":"","points":[{"desc":"・“找个老实人嫁了”本质是女性择偶从浪漫幻想向务实妥协的转变","detail":"1.浪漫幻想的背景：许多女性自小被灌输婚恋高期待，期待对方是浪漫、心动、风度翩翩、风趣幽默且有物质基础的\n2.妥协的触发因素：经历情感挫折或看清现实后，因需要陪伴和慰藉，被迫转向低风险、务实的选择\n3.老实人的价值定位：不是女性的憧憬或欲望，高情商是被坚持和可靠感动，低情商是风险规避的手段\n4.择偶价值的转变：从看重颜值、情商、新鲜感、浪漫感，转向务实、可靠和安全感","type":1}]},{"desc":"关系中的自我欺骗","timestamp":93000,"detail":"","points":[{"desc":"・妥协性择偶易引发关系中的相互自我欺骗，长期滋生隐忍与怨恨","detail":"1.自我欺骗的表现：女方欺骗自己对方可靠是“真正需要的人”，男方欺骗自己对方“真正认可自己”，双方陷入相互的幻觉\n2.自我欺骗的后果：比如女方朋友圈从未公开关系、亲朋好友不知情，最终因年纪到了结婚却又出轨\n3.自我欺骗的本质：“需要”不等于“认可”，长期相处会滋生彼此的隐忍与怨恨（中年女性聚集数落不在场的男人）","type":1}]},{"desc":"《革命之路》的启示","timestamp":190000,"detail":"","points":[{"desc":"・《革命之路》揭示妥协性婚姻因缺乏真诚与共同成长而走向悲剧","detail":"1.艾波的婚姻困境：有才华、懂浪漫的她因需要安稳进入婚姻，却因这份安稳感到日复一日的窒息和精神停滞\n2.巴黎计划的本质：是艾波对浪漫冒险的幻想，无细节、数字或柴米油盐的规划，只是抽象的符号\n3.悲剧的根源：婚姻的“土壤”本就有问题——二人的共同生活是“彼岸的远水”，而一方需要陪伴、一方需要安稳是“此岸的渴求”，缺乏真诚欣赏与共同成长","type":1}]}],"chapter_recommend_type":1,"chapter_abstract":"“找个老实人嫁了吧”反映了女性在经历情感挫折和看清现实后，选择妥协的择偶心态。这种心态可能导致关系中的自我欺骗和怨恨，最终影响彼此的成长。真正的关系应该建立在真诚欣赏和共同成长的基础上，而不是用远水解近渴。","chapter_recommend_source":2,"push_scene":[],"chapter_bar_color":null},"ad_charge_passive_unlock_config":{"trial_btn_config":{"btn_show_second":3,"btn_text":"秒后解锁本集","btn_show_frequency":1,"show_second_type":2},"broadcast_btn_config":{"btn_show_second":5,"btn_text":"秒后解锁下一集","btn_show_frequency":1,"show_second_type":2}},"common_button":{"button_list":[{"basic_info":{"btn_name":"playlet_iaa_next","exemptions":[1,2],"btn_type":"entertainment","btn_ui_style":0,"buttons":[{"content":{"content":""},"click_action":{"click_action":1,"btn_data_Keys":null,"behavior_type":0},"btn_data_keys":null}],"btn_datas":null},"priority":200400}]},"trends_infos":null,"chapter_bar_color":null},{"aweme_id":"7608567320880909594","desc":