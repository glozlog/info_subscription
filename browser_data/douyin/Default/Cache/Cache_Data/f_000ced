on":null,"slides_music_beats":null,"jump_tab_info_list":null,"media_type":4,"play_progress":{"play_progress":0,"last_modified_time":0},"reply_smart_emojis":null,"activity_video_type":-1,"boost_status":0,"create_scale_type":null,"entertainment_product_info":{"sub_title":null,"market_info":{"limit_free":{"in_free":false},"marketing_tag":null}},"caption":"#性 #欲望 #人文星闪耀计划","item_title":"SM里能否发现爱情","is_use_music":false,"original":0,"xigua_base_info":{"status":0,"star_altar_order_id":0,"star_altar_type":0,"item_id":0},"mark_largely_following":false,"friend_recommend_info":{"friend_recommend_source":10,"label_user_list":null,"disable_friend_recommend_guide_label":false},"enable_comment_sticker_rec":false,"video_share_edit_status":0,"is_24_story":0,"recommend_chapter_info":{"recommend_chapter_list":[{"desc":"引言","timestamp":1000,"detail":"","points":[]},{"desc":"游戏中易诞生爱的原因","timestamp":49000,"detail":"","points":[{"desc":"・SM游戏中易诞生爱的感觉与人性弱点暴露及情与欲分界模糊相关","detail":"1. 游戏天然放大人性弱点：SM游戏比普通恋爱、伴侣关系更快更狠，促使参与者暴露不敢暴露的欲望、弱点和匮乏\n2. 暴露带来的极致幻觉：心灵上袒露真实自我，身体上奔向虚幻目标获得满足，产生极致幻觉，将游戏视为“家”“温暖”和“港湾”\n3. 情与欲分界模糊：这种暴露让参与者无法精确切割自己的情与欲，容易在过程中产生爱的感觉","type":1}]},{"desc":"情感与欲望的交织","timestamp":98500,"detail":"","points":[{"desc":"・情感与欲望的交织会破坏情欲关系的权力结构","detail":"1. 情欲的本质区别：欲望与情感是两回事，谈恋爱也遵循这一规律，当两人从暧昧拉扯变得认真时，情感生长会让动作变形、自我心态慌乱\n2. 上位者失权的后果：任何情欲关系中，上位者突然失权、变得卑微（如想走进循规蹈矩的正常生活），其维持的欲望形象会彻底坍塌（如潇洒不羁的坏男人坠入爱河后，无力承担他者的欲望角色，便不再被欲望）\n3. 欲望的去人格化：下位者的渴求多是抽象的“位置”，而非具体的人；当上位者变弱，无法承担欲望和权力的秩序时，关系会失衡\n4. 坏倾向的涌现：当情与欲无法精确切割时，自私、占有欲、嫉妒心、破坏欲等爱情里的坏倾向会浮出水面，过往稳定的权力结构、游戏结构彻底坍塌","type":1},{"desc":"・情欲关系的权力结构难以维持源于情感与欲望的不可分割","detail":"1. 权力结构的本质：欲望的游戏本质是权力的游戏，若情与欲彼此交织、情感表露，权力结构会随之坍塌\n2. 人的需求矛盾：即使是看似无懈可击的女神、男神、支配者或上位者，也需要温暖和忠诚的拥抱，想要不计后果的狂热真挚爱情\n3. 维持的难度：需要极高的智慧才能维持情欲的权力结构，普通人难以做到全身而退","type":1}]},{"desc":"结语","timestamp":237000,"detail":"","points":[]}],"chapter_recommend_type":1,"chapter_abstract":"SM游戏中可能会发现爱情，但这种爱情往往伴随着痛苦和危险。游戏会放大人性弱点，让人在情感和欲望上产生混淆。当情感和欲望交织时，权力结构会崩溃，导致各种坏倾向浮出水面。要在情和欲之间维持精确的分离，才能守护现有的权利结构和游戏方式。","chapter_recomm