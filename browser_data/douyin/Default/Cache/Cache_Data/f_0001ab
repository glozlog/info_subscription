,"activity_video_type":-1,"boost_status":2,"create_scale_type":null,"entertainment_product_info":{"sub_title":null,"market_info":{"limit_free":{"in_free":false},"marketing_tag":null}},"caption":"回溯存在主义之父，克尔凯郭尔 #哲学 #知识分享 #存在主义 #人文星闪耀计划 #用知识解构社会现实","item_title":"存在主义是什么？","is_use_music":false,"original":0,"xigua_base_info":{"status":0,"star_altar_order_id":0,"star_altar_type":0,"item_id":0},"mark_largely_following":false,"friend_recommend_info":{"friend_recommend_source":10,"label_user_list":null,"disable_friend_recommend_guide_label":false},"enable_comment_sticker_rec":false,"video_share_edit_status":0,"is_24_story":0,"recommend_chapter_info":{"recommend_chapter_list":[{"desc":"引言","timestamp":1000,"detail":"","points":[]},{"desc":"存在主义的金句","timestamp":33000,"detail":"","points":[{"desc":"・存在主义的金句凝聚了哲学家对生命与存在的核心思考","detail":"1.克尔凯郭尔的“生命必须向前活，但只能向后理解”；2.尼采的“上帝死了”“对待生命不妨大胆一点，因为我们终将失去它”；3.萨特的“他人即地狱”“人是一堆无用的热情”；4.加缪的“没有对生活的绝望，就没有对生活的热爱”","type":1}]},{"desc":"克尔凯郭尔的比喻","timestamp":64000,"detail":"","points":[{"desc":"・克尔凯郭尔用“车夫与两匹马”的比喻阐述存在主义核心","detail":"1.比喻内容：人是车夫，生活是马车，拉车的马有两匹——天马（近乎无限速度、华丽身影）、老马（缓慢速度、笨拙步态）；2.痛苦原因：人需同时驾驭两匹马，意识的无限与现实的有限导致存在的痛苦","type":1}]},{"desc":"意识的无限性","timestamp":116000,"detail":"","points":[{"desc":"・意识的无限性体现为人的无限想象与自由","detail":"1.无法耗尽的意识：人可以不断想象不同的面孔、职业过往、生活抉择；2.无限的自由：可以想象比现在更成功，甚至换地点和时间的生活，有无尽自由想象成除自己以外的任何东西；3.脑海的遐想：肉身在此刻此处，但脑海难以停住当下，不停遐想","type":1}]},{"desc":"现实的有限性","timestamp":157000,"detail":"","points":[{"desc":"・现实的有限性表现为人受具体条件的桎梏","detail":"1.限制来源：受自己的身体、收入、性格所桎梏；2.经验干扰：被有限的、固定的具体自我经验干扰，被迫承认自己的脸、过去选择、性格懦弱、有限出身","type":1}]},{"desc":"存在的困境","timestamp":191000,"detail":"","points":[{"desc":"・存在的困境源于意识无限与现实有限的张力","detail":"1.追逐成功的累：意图让现实追赶上意识，老马永远追不上天马，无法成为想象中的自己；2.活得弱的表现：聚焦有限经验，无法想象、行动、跨越，锁死天马阻碍意识想象","type":1}]},{"desc":"存在主义的启示","timestamp":305000,"detail":"","points":[{"desc":"・存在主义为面临存在困境的人提供启示与安慰","detail":"1.适用人群：对自己存在的困境有过思索的人；2.对人生意义选择感到不安的人；3.对生活此刻感到怀疑的人；4.无法心安理得毫无怀疑过常人生活的人","type":1}]},{"desc":"结语","timestamp":350000,"detail":"","points":[]}],"chapter_recommend_type":1,"chapter_abstract":"存在主义探讨了人类存在的困境，即意识的无限性与现实的有限性之间的张力。克尔凯郭尔认为人是车夫，生活是马车，拉车的马有两匹，一匹是天马，一匹是老马。意识的无限性使人无法耗尽自我的意识，而现实的有限性则限制了我们的行动。存在主义者如克尔凯郭尔、尼采、萨特、加缪等，通过他们的思想和作品，揭示了人类存在的困境，并提供了启示和安慰。","chapter_recommend_source":2,"push_scene":[],"chapter_bar_color":null},"ad_charge_passive_unlock_config":{"trial_btn_config":{"btn_show_second":3,"btn_text":"秒后解锁本集","btn_show_frequency":1,"show_second_type":2},"broadcast_btn_config":{"btn_show_second":5,"btn_text":"秒后解锁下一集","btn_show_frequency":1,"show_second_type":2}},"common_button":{"button_list":[{"basic_info":{"btn_name":"playlet_iaa_next","exemptions":[1,2],"btn_type":"entertainment","btn_ui_style":0,"buttons":[{"content":{"content":""},"click_action":{"click_action":1,"btn_data_Keys":null,"behavior_type":0},"btn_data_keys":null}],"btn_datas":null},"priority":200400}]},"trends_infos":null,"chapter_bar_color":null,"flash_mob_trends":0,"ent_log_extra":{"log_extra":"{\"global_log_extra\":null,\"page_log_extra\":null,\"aweme_log_extra\":{\"ce_current_group_id\":\"7547904506231557391\",\"author_id\":\"3749764821694632\",\"ce_content_id\":\"7369879844835821622\",\"ce_content_type\":\"playlet\",\"ce_content_subtype\":\"3\",\"ce_item_pany_status\":\"success\",\"ce_item_succ_type\":\"free\",\"ce_content_pany_type\":\"free\",\"ce_item_pany_type\":\"free\",\"is_ce_paid_and_iaa\":\"0\"},\"extra_log_extra\":null}"}},{"aweme_id":"7614349612559715647","desc":"酒吧博弈经济学 #认知思维 #独立思考 #两性关系","create_time":1772854568,"author":{"uid":"3749764821694632","card_entries_not_display":null,"nickname":"狐狸的观念","personal_tag_list":null,"can_set_geofencing":null,"avatar_thumb":{"uri":"100x100/aweme-avatar/tos-cn-i-0813_owCnIA2ADGjAQeeglS3AhVCbhvY9CkA34IAnsX","url_list":["https://p3-pc.douyinpic.com/aweme/100x100/aweme-avatar/tos-cn-i-0813_owCnIA2ADGjAQeeglS3AhVCbhvY9CkA34IAnsX.jpeg?from=327834062"],"width":720,"height":720},"creator_tag_list":null,"risk_notice_text":"","follow_status":1,"data_label_list":null,"story25_comm