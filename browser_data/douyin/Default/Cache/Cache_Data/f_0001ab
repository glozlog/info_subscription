r_altar_order_id":0,"star_altar_type":0,"item_id":0},"mark_largely_following":false,"friend_recommend_info":{"friend_recommend_source":10,"label_user_list":null,"disable_friend_recommend_guide_label":false},"enable_comment_sticker_rec":false,"video_share_edit_status":0,"is_24_story":0,"recommend_chapter_info":{"recommend_chapter_list":[{"desc":"引言","timestamp":0,"detail":"","points":[]},{"desc":"自证陷阱的困境","timestamp":39000,"detail":"","points":[{"desc":"・年轻人在求职、工作、爱好中易陷入无限自证的困局","detail":"1.求职中的自证：年轻人求职需证明符合公司期待，即使拿出学历、专业，仍会被质疑课堂学习是否跟上市场变化\n2.工作中的自证：工作中需证明具备抗压能力，即使有实习经验，仍会被质疑实习内容无法代表真实工作\n3.爱好中的自证：有爱好需证明其值得追求，即使靠爱好赚钱，仍会被质疑是否是铁饭碗、能否持续赚钱","type":1}]},{"desc":"自证辩护的幻想","timestamp":114000,"detail":"","points":[{"desc":"・自证辩护是幻想，因怀疑与辩护存在不对称性","detail":"1.不对称性本质：怀疑无穷无尽，辩护终有尽头，陷入自证会永远无法脱身\n2.自媒体案例佐证：狐狸做自媒体时被质疑动机，若进行自证会产生新把柄，怀疑者会从新辩护中衍生新怀疑","type":1}]},{"desc":"标准米尺悖论","timestamp":149000,"detail":"","points":[{"desc":"・标准米尺悖论揭示了自证的逻辑困境","detail":"1.悖论内容：若用另一把一米长的尺子证明原尺子是一米，新尺子仍会被质疑，陷入无限自证循环\n2.生活类比：学历、专业、履历是衡量工作智识的基石，爱好、热情是衡量人生追求的基石，若质疑这些基石本身，则无法自证","type":1}]},{"desc":"正视人生选择的基石","timestamp":224000,"detail":"","points":[{"desc":"・解决自证陷阱需正视人生选择的基石并停止反身怀疑","detail":"1.明确人生基石：专业、履历、爱好、热情等就是人生选择的基石（如同尺子本身），不应反身测量\n2.行动建议：找到基点后停止反身怀疑，大胆选择行动，而非为行动找周全辩护\n3.内化质疑的危害：很多人内化了外界质疑，习惯为行动找辩护，导致失去行动力和生活热情","type":1}]},{"desc":"结语","timestamp":330000,"detail":"","points":[]}],"chapter_recommend_type":1,"chapter_abstract":"年轻人常常陷入自证陷阱，需要不断证明自己以满足他人的期待。这种无限自证的困局源于怀疑和辩护的不对称。要摆脱自证陷阱，我们需要正视人生选择的基石，相信自己的专业、履历、兴趣和热情，勇敢地行动，而不是在质疑面前不断辩护。","chapter_recommend_source":2,"push_scene":[],"chapter_bar_color":null},"ad_charge_passive_unlock_config":{"trial_btn_config":{"btn_show_second":3,"btn_text":"秒后解锁本集","btn_show_frequency":1,"show_second_type":2},"broadcast_btn_config":{"btn_show_second":5,"btn_text":"秒后解锁下一集","btn_show_frequency":1,"show_second_type":2}},"common_button":{"button_list":[{"basic_info":{"btn_name":"playlet_iaa_next","exemptions":[1,2],"btn_type":"entertainment","btn_ui_style":0,"button