]},{"desc":"男性的焦虑与自卑","timestamp":92000,"detail":"","points":[{"desc":"・男性对自身性能力的焦虑源于无法确信能否征服对方","detail":"1.男性会向伴侣小心求证满意度，却始终有理由怀疑对方只是在做伪装的满足；2.性能力的不确定性让男性对自身能力极度焦虑，心底里注定是敏感和自卑的","type":1}]},{"desc":"男性的弱点","timestamp":108000,"detail":"","points":[{"desc":"・男性的性弱点多与心理因素相关，医学定义难缓解焦虑","detail":"1.男性的性弱点（勃起障碍、早泄）一定程度上属于心理问题，因将性视为“考试”而非享受导致紧张脱离本能；2.国际性医学学会定义早泄为1分钟，国际疾病分类曾采用更短的15秒，生物学认为能让配偶怀孕即正常，但这些定义仍无法缓解男性焦虑","type":1}]},{"desc":"男性的责任与焦虑","timestamp":178000,"detail":"","points":[{"desc":"・男性因性中的主动角色承受焦虑与责任","detail":"1.男性在性中是主动方、执行人，必然要承担满足对方的责任，对面像是“审判官”；2.男性的欲望流动直抵不确定的黑洞，想向外界证明“你看我可以的”，始终无法确信能否真正满足对方","type":1}]},{"desc":"阉割的焦虑","timestamp":221000,"detail":"","points":[{"desc":"・拉康的“阉割焦虑”反映男性想摆脱性责任的渴望","detail":"1.拉康的“阉割焦虑”包含被阉割的渴望，男性不想再承担性责任、不想带永恒的枷锁；2.男性希望颠倒位置，成为被动的被捕食者、被征服者，让对方成为无限的征服者和上位者，从而放弃控制和责任","type":1}]}],"chapter_recommend_type":1,"chapter_abstract":"男性在性方面往往比女性更自卑敏感，因为他们永远无法确信是否真正征服了女人。这种不确定性导致他们在性方面强调掌控和对抗，同时也让他们对自己的能力极度焦虑。男性在性方面的责任和压力使得他们在欲望面前暗含着焦虑自卑，甚至渴望放弃责任，成为被动的一方。","chapter_recommend_source":2,"push_scene":[],"chapter_bar_color":null},"ad_charge_passive_unlock_config":{"trial_btn_config":{"btn_show_second":3,"btn_text":"秒后解锁本集","btn_show_frequency":1,"show_second_type":2},"broadcast_btn_config":{"btn_show_second":5,"btn_text":"秒后解锁下一集","btn_show_frequency":1,"show_second_type":2}},"common_button":{"button_list":[{"basic_info":{"btn_name":"playlet_iaa_next","exemptions":[1,2],"btn_type":"entertainment","btn_ui_style":0,"buttons":[{"content":{"content":""},"click_action":{"click_action":1,"btn_data_Keys":null,"behavior_type":0},"btn_data_keys":null}],"btn_datas":null},"priority":200400}]},"trends_infos":null,"chapter_bar_color":null},{"aweme_id":"7603572378978749748","desc":"教你诚实正直，却难容于世界 #独立思考 #认知思维 #人文星闪耀计划 #用知识解构社会现实","create_time":1770345362,"author":{"uid":"3749764821694632","card_entries_not_display":null,"nickname":"狐狸的观念","personal_tag_list":null,"can_set_geofencing":null,"avatar_thumb":{"uri":"100x100/aweme-avatar/tos-cn-i-0813_owCnIA2ADGj